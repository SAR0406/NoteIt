# NVIDIA NIM configuration for MBBS AI workflows
# Best-fit use case for this app: Retrieval Augmented Generation (notes + OCR/handwriting context)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_GENAI_BASE_URL=https://ai.api.nvidia.com/v1/genai
NVIDIA_NIM_MODEL=openai/gpt-oss-120b
NVIDIA_NIM_ASR_MODEL=openai/whisper-large-v3
# Prompt strategy label used by NoteIt to steer MBBS-focused generation behavior.
NVIDIA_NIM_USE_CASE=Retrieval Augmented Generation
